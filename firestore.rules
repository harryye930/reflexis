rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // This rule allows any authenticated user to read from the "public" path.
    match /artifacts/{appId}/public/{document=**} {
      allow read: if request.auth != null;
    }

    // This rule handles highlights specifically.
    match /artifacts/{appId}/public/data/highlights/{highlightId} {
        // Any authenticated user can create a highlight.
        allow create: if request.auth != null 
          && request.auth.uid == request.resource.data.userId;

        // Only the user who created the highlight can update or delete it.
        allow update, delete: if request.auth.uid == resource.data.userId;
    }

    // This rule handles codes management.
    match /artifacts/{appId}/public/data/codes/{codeId} {
        // Any authenticated user can read codes.
        allow read: if request.auth != null;

        // Any authenticated user can create a code.
        allow create: if request.auth != null;

        // Any authenticated user can update or delete any code.
        allow update, delete: if request.auth != null;
    }

    // This rule handles documents management.
    match /artifacts/{appId}/public/data/documents/{documentId} {
        // Any authenticated user can read documents.
        allow read: if request.auth != null;

        // Any authenticated user can create a document.
        allow create: if request.auth != null;

        // Any authenticated user can update or delete any document.
        allow update, delete: if request.auth != null;
    }

    // This rule handles user profiles.
    match /artifacts/{appId}/public/data/users/{userId} {
       // Any authenticated user can see who else is in the session.
       allow read: if request.auth != null;

       // A user can only create or update their own profile.
       allow write: if request.auth.uid == userId;
    }
  }
}
